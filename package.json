{
  "name": "@poxenstudio/myreader-monorepo",
  "private": true,
  "repository": "poxenstudio/myreader",
  "scripts": {
    "test": "pnpm --filter @poxenstudio/myreader test",
    "test:lua": "pnpm --filter @poxenstudio/myreader test:lua",
    "lint": "pnpm --filter @poxenstudio/myreader lint",
    "lint:lua": "pnpm --filter @poxenstudio/myreader lint:lua",
    "tauri": "pnpm --filter @poxenstudio/myreader tauri",
    "dev-web": "pnpm --filter @poxenstudio/myreader dev-web",
    "prepare": "husky",
    "fmt:check": "pnpm --filter @poxenstudio/myreader fmt:check",
    "clippy:check": "pnpm --filter @poxenstudio/myreader clippy:check",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "workspaces": [
    "app",
    "packages/*"
  ],
  "packageManager": "pnpm@11.1.1",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@sindresorhus/tsconfig": "^6.0.0",
    "husky": "^9.1.6",
    "lint-staged": "^16.2.7",
    "typescript": "^5"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,css,json}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
